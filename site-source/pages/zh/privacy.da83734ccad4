"success":"转换成功","convert_success":"转换成功","abort":"中止转换","select_format":"选择输出格式","output_format":"输出格式","start_convert":"开始转换","processing":"正在转换...","result_preview":"结果预览","download_video":"下载视频","file_size":"文件大小","dimensions":"分辨率","dimensions_tip":"自定义输出分辨率，将保持宽高比不变","duration":"时长","error_no_video":"未找到视频轨道","error_wasm":"WASM 模块初始化失败","error_convert":"转换失败，请重试","loading_wasm":"正在加载核心组件...","wasm_ready":"组件加载完成","wasm_failed":"组件加载失败","features":{"privacy":{"title":"隐私保护","description":"所有处理均在浏览器本地完成，视频文件不会上传到服务器，确保您的隐私绝对安全。"},"customization":{"title":"强大定制","description":"支持多种格式互转，可自定义输出分辨率，灵活调整转换参数。"},"efficiency":{"title":"高效转换","description":"采用先进的 WebAssembly 技术，利用本地算力快速转换，无需等待上传下载。"}},"faq":{"title":"常见问题","question1":"支持哪些视频格式的转换？","answer1":"支持 MP4、WebM、MOV、AVI、MKV 等常见格式之间的相互转换。","question2":"转换后的视频画质会损失吗？","answer2":"默认情况下会尽可能保持原始画质。某些格式转换（如 MOV 转 MP4）可能会有轻微画质变化，这是正常的编解码过程。","question3":"转换需要多长时间？","answer3":"转换速度取决于您的电脑性能、视频时长和分辨率。一般短视频可在几秒到几十秒内完成。"}},"gif-splitter":{"title":"GIF 分帧与编辑器","description":"上传动画 GIF 文件，将其拆分为独立帧。编辑帧顺序、时间和尺寸，然后重新导出为新的 GIF 或将帧下载为 PNG。","uploadTitle":"上传 GIF 文件","uploadDescription":"将 GIF 文件拖放到此处或点击选择","uploadHint":"支持动画 GIF 文件","decoding":"正在解码 GIF...","downloadFrame":"下载帧","downloadAllFrames":"下载所有帧","reExportGif":"导出编辑后的 GIF","originalInfo":"原始：{width}×{height}，{frameCount} 帧","splitComplete":"拆分完成！已提取 {count} 帧","resetUpload":"重新上传","features":{"split":{"title":"智能帧提取","description":"自动解码 GIF 帧并保持正确的时间间隔，处理所有帧处置方法和子帧合成。"},"edit":{"title":"完整帧编辑","description":"通过拖放重新排列帧序，删除不需要的帧，精确调整每帧的延迟时间。"},"privacy":{"title":"隐私保护","description":"所有处理均在浏览器本地完成，不会将任何文件上传到服务器。"}},"faq":{"title":"常见问题","question1":"支持哪些 GIF 文件？","answer1":"支持所有标准的 GIF87a 和 GIF89a 动画 GIF 文件，包括带有透明度和复杂帧处置方法的文件。","question2":"可以下载单独的帧吗？","answer2":"可以！您可以将任意单帧下载为 PNG 图片，也可以一次性将所有帧下载为 ZIP 压缩包。","question3":"编辑后的 GIF 能保持画质吗？","answer3":"重新编码的 GIF 使用同样高质量的 WASM 编码器。帧数据在整个编辑过程中以无损 RGBA 格式保存。"}},"pdf-to-image":{"title":"PDF 转图片工具","description":"在线免费将 PDF 页面转换为 PNG、JPEG 或 WEBP 图片。高质量，本地处理，无需上传。","start":"开始转换","processing":"处理中...","clear":"清除全部","downloadAll":"批量下载","selectPdf":"选择 PDF 文件进行转换","notSupport":"仅支持 .pdf 格式文件","tooManyFiles":"建议每批不超过 {count} 个文件以获得最佳性能","format":"输出格式","dpi":"分辨率 (DPI)","quality":"质量","mergePages":"图片拼接","mergeVertical":"垂直拼接（从上到下）","mergeHorizontal":"水平拼接（从左到右）","pages":"{count} 页","status":{"waiting":"等待中","processing":"处理中","done":"已完成","failed":"失败"},"size":{"original":"原始","unit":"MB","fileSize":"文件大小"},"features":{"multiFormat":{"title":"多格式输出","description":"支持将 PDF 页面转换为 PNG、JPEG 或 WEBP。PNG 画质最佳，JPEG 文件更小，WEBP 适合现代浏览器。"},"dpiControl":{"title":"DPI 分辨率控制","description":"可选 72、96、150 或 300 DPI，根据使用场景灵活平衡图片质量与文件大小。"},"multiPage":{"title":"多页面支持","description":"PDF 的每一页都会被单独渲染为图片，并打包为 ZIP 文件方便下载。"},"privacy":{"title":"100% 本地处理","description":"所有转换均在浏览器本地通过 WebAssembly 完成，PDF 文件不会上传到任何服务器。"},"fast":{"title":"快速转换","description":"高性能渲染引擎驱动，在浏览器中实现接近原生的 PDF 渲染速度。"},"batch":{"title":"批量处理","description":"支持同时上传多个 PDF 文件并批量转换，可单独或批量下载转换结果。"}},"faq":{"title":"常见问题","question1":"我的 PDF 会被上传到服务器吗？","answer1":"不会。所有处理均在您的浏览器本地通过 WebAssembly 技术完成，文件不会离开您的设备。","question2":"支持哪些输出格式？","answer2":"支持将 PDF 页面转换为 PNG（无损，画质最佳）、JPEG（文件更小）或 WEBP（现代格式，压缩效果好）。","question3":"应该选择哪个 DPI？","answer3":"72 DPI 适合屏幕显示；96 DPI 为标准屏幕分辨率；150 DPI 适合通用场景；300 DPI 推荐用于打印或高质量输出。","question4":"可以转换多页 PDF 吗？","answer4":"可以。每页都会被渲染为独立的图片，所有页面会打包成 ZIP 文件供下载。","question5":"文件大小有限制吗？","answer5":"没有硬性限制，但超大的 PDF 文件因浏览器内存限制处理速度较慢。建议文件大小在 100MB 以内。","question6":"每次可以转换几个 PDF 文件？","answer6":"文件数量没有硬性限制，文件会逐个处理以确保稳定性。为获得最佳性能，建议每批不超过 20 个文件。"}},"doc-compressor":{"title":"办公文件压缩工具","description":"免费在线压缩 PDF、Word（DOCX）和 PowerPoint（PPTX）文件，最多减小 80% 文件体积。操作简单、无需注册、不上传服务器，100% 本地处理保障隐私安全。","start":"开始压缩","processing":"压缩中...","clear":"清除全部","downloadAll":"下载全部","selectDoc":"选择 PDF、DOCX 或 PPTX 文件进行压缩","notSupport":"仅支持 .pdf、.docx 和 .pptx 文件","tooManyFiles":"建议每批不超过 {count} 个文件以获得最佳性能","quality":"质量","format":"格式","pages":"{count} 页","originalSize":"原始大小","compressedSize":"压缩后大小","reduced":"-{percent}%","status":{"waiting":"等待中","processing":"处理中","done":"完成","failed":"失败"},"progress":{"extracting":"解压文件","compressingImages":"压缩图片","updatingRefs":"更新引用","optimizingXml":"优化文件","packing":"打包文件","processingFile":"处理文件"},"size":{"unit":"MB"},"features":{"multiFormat":{"title":"多格式支持","description":"同时支持 PDF、Word（DOCX）和 PowerPoint（PPTX）文件压缩，自动识别文件格式，混合上传批量处理。"},"smartCompression":{"title":"智能压缩","description":"智能减小 PDF、Word 和 PowerPoint 文件体积，同时尽量保持文档清晰度、版式和可用性。"},"dpiControl":{"title":"DPI 分辨率控制","description":"PDF 压缩会根据所选质量自动调整渲染分辨率，在图像清晰度和文件大小之间取得最佳平衡。"},"qualityControl":{"title":"质量控制","description":"调整 JPEG/WebP 压缩质量（50%~95%），在文件大小和清晰度之间找到完美平衡。"},"privacy":{"title":"100% 本地处理","description":"所有压缩过程均通过 WebAssembly 在浏览器中完成。您的文件不会上传到任何服务器。"},"batch":{"title":"批量处理","description":"上传多个文件并一次性压缩。PDF、DOCX 和 PPTX 可混合上传，单独下载或打包为 ZIP 压缩包。"}},"faq":{"title":"常见问题","question1":"支持哪些文件格式？","answer1":"目前支持 PDF、Word（DOCX）和 PowerPoint（PPTX）三种格式。您可以混合上传不同格式的文件，工具会自动识别并分别处理。","question2":"压缩是如何工作的？","answer2":"工具会根据文件内容自动选择合适的压缩方式，在减小体积的同时尽量保持文档清晰、可打开、可正常使用。","question3":"文件安全吗？会上传到服务器吗？","answer3":"完全安全。所有处理都在您的浏览器中通过 WebAssembly 技术完成，文件不会离开您的设备，也不会上传到任何服务器。","question4":"压缩后文件质量会变差吗？","answer4":"您可以自由调节压缩质量（50%~95%）。质量越高，文件越大但越清晰；质量越低，压缩率越高。建议选择 75%~85% 获得最佳平衡。","question5":"压缩后的文件能正常使用吗？","answer5":"可以。压缩后的文件保持完整结构，可用 Microsoft Word、WPS、PowerPoint、Adobe Acrobat 等软件正常打开和编辑。","question6":"压缩率一般是多少？","answer6":"取决于文件内容。图片较多的文档通常压缩率更高；纯文字文档本身体积较小，压缩空间也会更有限。"}},"feedback":{"title":"发送反馈","description":"您的反馈帮助我们改进 ZipImg。分享您的使用体验或建议。","rating":{"label":"评分","required":"请选择评分","stars":"{count} 星"},"content":{"label":"反馈内容","placeholder":"请描述您的使用体验、报告问题或提出建议...","required":"请输入反馈内容"},"submit":"提交反馈","submitting":"提交中...","success":{"title":"感谢您的反馈！","description":"您的反馈已成功提交，我们会认真参考。感谢您帮助 ZipImg 变得更好。"},"error":{"title":"提交失败","rateLimit":"提交过于频繁，请稍后再试。","generic":"发生错误，请重试。"}},"privacy":{"title":"隐私政策","lastUpdated":"最后更新：2025-01-01","overview":{"title":"概述","content":"本隐私政策说明我们的图片压缩工具在您使用服务时如何收集、使用和保护您的信息。"},"localProcessing":{"title":"本地处理","content":"我们的图片压缩工具使用 WebAssembly（WASM）技术，完全在您的设备上处理图片。您的图片永远不会上传到我们的服务器，所有压缩操作均在浏览器本地完成。"},"infoCollect":{"title":"我们收集的信息","content":"我们仅收集提供服务所必需的最少信息：","listItem1":"使用数据，如页面访问和使用的功能（通过匿名分析）","listItem2":"技术数据，如浏览器类型和设备信息","noCollect":"我们不会收集或存储您的图片或您压缩的文件内容。"},"cookies":{"title":"Cookie","content":"我们使用必要的 Cookie 来确保网站正常运行。您可以通过浏览器设置管理 Cookie。"},"thirdParty":{"title":"第三方服务","content":"我们可能会使用第三方分析服务来帮助改进我们的网站。这些服务可能会收集有关您使用我们网站的信息。"},"dataSecurity":{"title":"数据安全","content":"由于您的图片在本地处理且不会发送到我们的服务器，您的图片在我们这边不存在泄露风险。尽管如此，我们仍然采取标准安全措施来保护我们收集的信息。"},"changes":{"title":"政策变更","content":"我们可能会不时更新隐私政策。如有变更，我们会通过在本页面发布新的隐私政策来通知您。"},"contact":{"title":"联系我们","content":"如果您对本隐私政策有任何疑问，请联系我们："},"backHome":"← 返回首页"}},"now":"$undefined","timeZone":"UTC","children":"$L16"}]
